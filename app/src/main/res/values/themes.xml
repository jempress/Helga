<resources xmlns:tools="http://schemas.android.com/tools">
    <style name="Theme.WifiFtp" parent="android:Theme.Material.Light.NoActionBar">
        <item name="android:windowBackground">@color/app_background</item>
        <item name="android:statusBarColor">@android:color/transparent</item>
        <item name="android:navigationBarColor">@android:color/transparent</item>
        <item name="android:windowDrawsSystemBarBackgrounds">true</item>
    </style>

    <!-- Cold-start splash screen — shows the Valkyrie icon on the logo's
         own gold background before the app's UI is ready, on every Android
         version (the core-splashscreen library backports this to API 21+). -->
    <style name="Theme.Helga.Splash" parent="Theme.SplashScreen">
        <item name="windowSplashScreenBackground">@color/ic_launcher_background</item>
        <item name="windowSplashScreenAnimatedIcon">@drawable/splash_icon</item>
        <item name="postSplashScreenTheme">@style/Theme.WifiFtp</item>
    </style>
</resources>
